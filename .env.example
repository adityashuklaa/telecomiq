# ─────────────────────────────────────────────────────────────
# TelecomIQ configuration. Copy to `.env` and fill in real values.
# NEVER commit the real .env file (it is in .gitignore).
# ─────────────────────────────────────────────────────────────

# --- Anthropic / Claude API (Module 4: Revenue Intelligence) ---
# Get a key at https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx
CLAUDE_MODEL=claude-opus-4-8

# --- PostgreSQL ---
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=telecomiq
POSTGRES_USER=telecomiq
POSTGRES_PASSWORD=change_me_in_production

# --- Kafka ---
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_TOPIC_CDR=cdr-stream
KAFKA_TOPIC_NETWORK=network-stream

# --- API ---
API_HOST=0.0.0.0
API_PORT=8000
# URL the dashboard uses to reach the API (inside docker network use http://api:8000)
API_BASE_URL=http://api:8000

# --- App ---
LOG_LEVEL=INFO
MODEL_DIR=/app/artifacts
DATA_DIR=/app/data/generated
